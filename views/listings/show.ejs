<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h5 class="card-title"><%= listing.title %></h5>
            
            <div class="card listing-card col-6">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
                <div class="card-body">
                    <p class="card-text"> 
                        <i> Owned by <%= listing.owner ? listing.owner.username : "Unknown User" %> </i>
                    </p> 
                    <p class="card-text"><%= listing.description %></p>
                    <p class="card-text">&#x20B9; <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %></p>
                    <p class="card-text"><%= listing.location %></p>
                    <p class="card-text"><%= listing.country %></p>
                </div>          
            </div>

            <% if(curUser && listing.owner && listing.owner._id.equals(curUser._id)) { %>
                <div class="btns"> 
                    <a class="btn btn-dark" href="/listings/<%= listing._id %>/edit">Edit</a>
                </div>
                <br> 
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-dark add-btn">Delete</button>
                </form>  
            <% } %>

            <div class="col-8 offset-0">
                <% if(curUser) { %>
                    <hr>
                    <h4>Leave a Review</h4>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                        <div class="mb-3 mt-3">
                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>

                        <div class="mb-3 mt-3">
                            <label for="comment">Comments</label>
                            <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                            <div class="invalid-feedback">
                                Please provide a comment! 
                            </div>
                        </div>
                        <button class="mb-3 btn btn-outline-dark">Submit</button>
                    </form>
                <% } %>
                
                <hr>
                <% if(listing.reviews.length>0){  %>
                <p><b>All Reviews</b></p>
                <div class="row">
                    <% for(let review of listing.reviews) { %>
                        <div class="card col-5 ms-3 mb-3" id="review-<%= review._id %>">
                            <div class="card-body">
                                <h5 class="card-title">@<%= review.author.username %></h5>
                                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                <p class="card-text"><%= review.comment %></p>
                            </div>  
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3 ms-3">
                                <button class="btn btn-dark btn-sm">Delete</button>
                            </form>
                        </div>
                    <% } %>
                    <% } %>
                </div>
            </div>

            <hr>
            <div class="col-8 offset-0 mb-3">
                <h3>Where you will be</h3>
                <div id="map"></div>
            </div> 
            
        </div>
    </div>
    <script>
    // Database se coordinates nikalna (EJS use karke)
    // Maan lete hain aapke paas listing.coordinates = [lat, lng] format mein hai:
    const lat = <%= listing.coordinates ? listing.coordinates[0] : 20.5937 %>;
    const lng = <%= listing.coordinates ? listing.coordinates[1] : 78.9629 %>;

    // 1. Map initialize karein dynamic coordinates ke sath
    const map = L.map('map').setView([lat, lng], 13);

    // 2. OpenStreetMap tiles load karein
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    // 3. Dynamic Marker add karein aur listing ka title popup mein dikhayein
    L.marker([lat, lng]).addTo(map)
        .bindPopup("<b><%= listing.title %></b><br><%= listing.location %>")
        .openPopup();
</script>
</body>